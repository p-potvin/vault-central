{
  "manifest_version": 3,
  "name": "Favorites Central",
  "version": "1.1.1",
  "description": "The ultimate video saver. Organize and access all your favorite video sources from any website in one central location.",
  "browser_specific_settings": {
    "gecko": {
      "id": "favorites-central@p-potvin",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["storage", "activeTab", "scripting", "webRequest", "alarms", "tabs"],
  "optional_permissions": ["notifications"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Open Favorites Central",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/scripts/background.js",
    "scripts": ["background/scripts/background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+F"
      }
    },
    "capture-video": {
      "suggested_key": {
        "default": "Alt+X"
      },
      "description": "Capture video source URL under mouse"
    }
  }
}