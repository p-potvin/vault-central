{
  "manifest_version": 3,
  "name": "Favorites Central",
  "version": "2.0.0",
  "description": "The ultimate video saver. Organize and access all your favorite video sources from any website in one central location.",
  "browser_specific_settings": {
    "gecko": {
      "id": "favorites-central@p-potvin",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "idle",
    "search",
    "tabGroups",
    "menus.overrideContext",
    "activeTab",
    "cookies",
    "scripting",
    "webRequest",
    "webRequestAuthProvider",
    "webRequestBlocking",
    "webRequestFilterResponse",
    "webRequestFilterResponse.serviceWorkerScript",
    "alarms",
    "storage",
    "unlimitedStorage",
    "contextualIdentities",
    "captivePortal",
    "identity",
    "declarativeNetRequestWithHostAccess",
    "menus",
    "contextMenus",
    "dns",
    "theme",
    "clipboardRead",
    "clipboardWrite",
    "geolocation",
    "notifications",
    "bookmarks",
    "browsingData",
    "browserSettings",
    "topSites",
    "find",
    "history",
    "pkcs11",
    "declarativeNetRequestFeedback",
    "sessions",
    "devtools",
    "tabs",
    "tabHide",
    "webNavigation",
    "downloads",
    "downloads.open",
    "privacy",
    "nativeMessaging",
    "proxy",
    "management",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {
    "default_title": "Open Favorites Central",
    "default_popup": "pin-entry.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "oauth2": {
    "client_id": "YOUR_GOOGLE_CLOUD_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "background": {
    "scripts": ["background/scripts/background.js"],
    "service_worker": "background/scripts/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+C"
      },
      "description": "Opens the dashboard"
    },
    "capture-video": {
      "suggested_key": {
        "default": "Alt+X"
      },
      "description": "Capture video source URL under mouse"
    }
  }
}