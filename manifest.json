{
  "manifest_version": 3,
  "name": "Vault Central | VaultWares",
  "short_name": "Vault Central",
  "version": "3.4.3",
  "description": "A browser extension to save and revisit your favorite videos from around the web. Fully encrypted locally so only you can ever access it. Losing your PIN is not recommended.",
  "browser_specific_settings": {
    "gecko": {
      "id": "vault-central@p-potvin",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage",
    "scripting",
    "alarms",
    "tabs",
    "unlimitedStorage",
    "webRequest",
    "downloads",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' * data: blob:;"
  },
  "sandbox": {
    "pages": ["src/offscreen/sandbox.html"]
  },
  "action": {
    "default_title": "Access Vault Central",
    "default_popup": "pin-entry.html",
    "default_icon": {
      "16": "icons/vaultwares-gold-filled-16.png",
      "32": "icons/vaultwares-gold-filled-32.png",
      "48": "icons/vaultwares-gold-filled-48.png",
      "128": "icons/vaultwares-gold-filled-128.png"
    }
  },
  "icons": {
    "16": "icons/vaultwares-gold-filled-16.png",
    "32": "icons/vaultwares-gold-filled-32.png",
    "48": "icons/vaultwares-gold-filled-48.png",
    "128": "icons/vaultwares-gold-filled-128.png"
  },
  "background": {
    "service_worker": "background-worker.js",
    "scripts": ["background-worker.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content.js",
        "dashboard-v2.html",
        "pin-entry.html",
        "dashboard.js",
        "pin.js",
        "vault-themes.js",
        "vault-themes.css",
        "ffmpeg-core/ffmpeg-core.js",
        "ffmpeg-core/ffmpeg-core.wasm",
        "ffmpeg-core/ffmpeg-worker.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+C"
      },
      "description": "Opens the Vault dashboard"
    },
    "capture-video": {
      "suggested_key": {
        "default": "Alt+X"
      },
      "description": "Captures the video under your cursor"
    }
  }
}
