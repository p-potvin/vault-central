{
  "manifest_version": 3,
  "name": "VaultWares — Vault Central",
  "short_name": "Vault Central",
  "version": "3.2.0",
  "description": "Privacy-first video vault by VaultWares. One keystroke saves any video or link under your cursor — encrypted locally, never shared.",
  "author": "VaultWares",
  "homepage_url": "https://github.com/p-potvin/vault-central",
  "browser_specific_settings": {
    "gecko": {
      "id": "vault-central@p-potvin",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage",
    "scripting",
    "alarms",
    "tabs",
    "unlimitedStorage",
    "webRequest",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {
    "default_title": "Open Vault Central",
    "default_popup": "pin-entry.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "scripts": ["background/scripts/background.js"],
    "service_worker": "background/scripts/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+C"
      },
      "description": "Opens the dashboard"
    },
    "capture-video": {
      "suggested_key": {
        "default": "Alt+X"
      },
      "description": "Capture video source URL under mouse"
    }
  }
}