{
  "name": "vault-central",
  "version": "3.2.0",
  "description": "VaultWares Vault Central — a privacy-first browser extension that instantly saves videos and links under your cursor into an AES-256-encrypted local vault, complete with a fully themed dashboard, HLS stream interception, FFmpeg preview generation, and optional PIN lock.",
  "main": "content.js",
  "scripts": {
    "dev": "vite",
    "build": "python scripts/generate-themes.py && tsc && vite build && npx esbuild src/scripts/content.ts --bundle --outfile=dist/content.js --format=iife --target=es2020 --minify && npx esbuild background/scripts/background.ts --bundle --outfile=dist/background/scripts/background.js --format=iife --target=es2020 --minify && npx esbuild src/offscreen/processor.ts --bundle --outfile=dist/src/offscreen/processor.js --format=iife --target=es2020 --minify && node package-extension.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/p-potvin/vault-central.git"
  },
  "keywords": ["browser-extension", "video-vault", "privacy-first", "vaultwares", "videos", "favorites", "bookmarks", "save", "dashboard", "customization", "secured", "hls", "m3u8", "indexed-db", "aes-256"],
  "author": "VaultWares",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/p-potvin/vault-central/issues"
  },
  "homepage": "https://github.com/p-potvin/vault-central#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.38",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.0",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.19",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.38",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-static-copy": "^4.0.0",
    "vitest": "^4.1.0",
    "webextension-polyfill": "^0.12.0",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@tanstack/react-query": "^5.95.0",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "dexie": "^4.3.0",
    "esbuild": "^0.27.7",
    "hls.js": "^1.6.15",
    "lucide-react": "^0.577.0",
    "mux.js": "^6.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "type": "module"
}
